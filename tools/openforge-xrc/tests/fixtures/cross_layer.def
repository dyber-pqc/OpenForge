VERSION 5.8 ;
DESIGN xlayer ;
UNITS DISTANCE MICRONS 1000 ;
DIEAREA ( 0 0 ) ( 10000 10000 ) ;
COMPONENTS 2 ;
- a sky130_fd_sc_hd__inv_1 + PLACED ( 1000 1000 ) N ;
- b sky130_fd_sc_hd__inv_1 + PLACED ( 5000 1000 ) N ;
END COMPONENTS
NETS 2 ;
- netA ( a Y )
  + ROUTED met1 ( 1000 1500 ) ( 5000 1500 ) ;
- netB ( b A )
  + ROUTED met2 ( 1000 1500 ) ( 5000 1500 ) ;
END NETS
END DESIGN
