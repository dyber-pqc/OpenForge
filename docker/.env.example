# OpenForge EDA - Docker Compose Environment Variables
# Copy to .env and modify for your deployment

# PostgreSQL
POSTGRES_PASSWORD=change_me_in_production

# MinIO (Object Storage)
MINIO_ACCESS_KEY=openforge
MINIO_SECRET_KEY=change_me_in_production

# API Secret Key (for JWT token signing)
SECRET_KEY=change_me_to_a_random_64_char_string

# Optional: External tool container registry
# TOOL_REGISTRY=ghcr.io/dyber-pqc
